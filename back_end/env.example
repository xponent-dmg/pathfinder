# Server
PORT=5050

# Database
# TODO: paste your MongoDB connection string
MONGODB_URI=

# Auth
# TODO: set a strong secret
JWT_SECRET=

# Scraper
# Toggle the scheduled scraper (true/false)
ENABLE_EVENT_SCRAPER=false

# TODO: set the real events page URL, e.g. https://example.com/events
SCRAPER_SOURCE_URL=

# Cron schedule (default: every 6 hours)
SCRAPER_CRON=0 */6 * * *

# CSS selectors for the scraper (customize to your target site)
# These are defaults; override if your target site differs
SCRAPER_CARD_SELECTOR=.event-card
SCRAPER_TITLE_SELECTOR=.title
SCRAPER_DATE_SELECTOR=.date
SCRAPER_VENUE_SELECTOR=.venue
SCRAPER_DESC_SELECTOR=.desc
SCRAPER_LINK_SELECTOR=a
